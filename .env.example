# Copy this file to `.env` and fill in the values you want. `.env` is git-ignored.
# Every variable here is optional — anything you leave blank uses the default.

# ---- Hugging Face -----------------------------------------------------------
# Personal access token. Only required for gated/private models.
# The public `Systran/faster-whisper-large-v3` model does NOT need a token.
# Create one at https://huggingface.co/settings/tokens (Read scope is enough).
HF_TOKEN=

# Optional: use an alternate Hugging Face endpoint (e.g. a mirror) for model
# downloads. Leave empty to use the official https://huggingface.co.
# Example: HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional: where Hugging Face caches downloaded models. Leave empty for the
# default (%USERPROFILE%\.cache\huggingface\hub on Windows).
HF_HOME=

# ---- Ollama -----------------------------------------------------------------
# Base URL of your local Ollama server. Leave empty for http://localhost:11434.
OLLAMA_HOST=

# Default Ollama model used for transcript analysis. Override per-run with
# --ollama-model. Must be a model you've pulled via `ollama pull <name>`.
OLLAMA_MODEL=qwen3.5:latest

# ---- Whisper ----------------------------------------------------------------
# Default Whisper model size. Override per-run with --model.
# Common values: large-v3, large-v3-turbo, medium, small, base, tiny.
WHISPER_MODEL=large-v3

# Device for inference: cuda, cpu, or auto. Override with --device.
WHISPER_DEVICE=cuda

# CTranslate2 compute type. Override with --compute-type.
# Good choices: float16 (GPU), int8_float16 (GPU, lower VRAM), int8 (CPU).
WHISPER_COMPUTE_TYPE=float16

# ---- Output -----------------------------------------------------------------
# Root directory for per-video output folders. Override with --output-dir.
OUTPUT_DIR=output
